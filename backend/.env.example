# Server
PORT=3000
FRONTEND_URL=http://localhost/bahaytekUI

# MongoDB Atlas — paste your connection string here
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bahaytek?retryWrites=true&w=majority

# JWT — use a long random secret (32+ characters)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Facebook OAuth — https://developers.facebook.com/
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback
